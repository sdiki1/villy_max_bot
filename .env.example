# MAX bot
MAX_BOT_TOKEN=
MAX_SKIP_UPDATES=true

# Optional local path to image used in welcome message
WELCOME_IMAGE_PATH=welcome.jpeg

# Admin panel auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_SESSION_SECRET=change_me_long_random_secret

# App
APP_HOST=0.0.0.0
APP_PORT=8001

# Postgres
POSTGRES_DB=villyprint
POSTGRES_USER=villyprint
POSTGRES_PASSWORD=villyprint
DATABASE_URL=postgresql+asyncpg://villyprint:villyprint@db:5432/villyprint

# Telegram admin notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MAX_NOTIFY_CHAT_ID=-72352444311745
ADMIN_URL=http://localhost:8001/admin/chats

# Wildberries questions auto-reply worker
WB_API_TOKEN=
WB_AUTO_REPLY_POLL_INTERVAL=30
# For Base/Basic WB tokens use 720. Leave unset for automatic inference.
# WB_API_MIN_INTERVAL_SECONDS=720

# Gemini AI for WB feedback replies
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.4
